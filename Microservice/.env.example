# Nerve IDP — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# In production, all secrets are injected by HashiCorp Vault.

# ── App ─────────────────────────────────────────────────
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────
# Application connects through PgBouncer — NEVER direct PostgreSQL
DATABASE_URL=postgresql+asyncpg://nerve_app:nerve_app_secret@localhost:6432/nerve
DATABASE_URL_SYNC=postgresql+psycopg2://nerve_app:nerve_app_secret@localhost:6432/nerve

# Alembic migrations connect direct — PgBouncer transaction mode incompatible with DDL
DATABASE_URL_MIGRATIONS=postgresql+psycopg2://nerve:nerve_dev_secret@localhost:5432/nerve

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://:nerve_redis_secret@localhost:6379/0
USE_REDIS_SENTINEL=false

# ── Neo4j ────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nerve_neo4j_secret

# ── Vault ────────────────────────────────────────────────
VAULT_URL=http://localhost:8200
VAULT_TOKEN=nerve-vault-dev-token

# ── Temporal ─────────────────────────────────────────────
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# ── OPA ──────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── JWT ──────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION. Use `openssl rand -hex 32`
JWT_SECRET_KEY=nerve-jwt-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=

# ── AWS ──────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Slack ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_ALERTS_CHANNEL=#nerve-alerts

# ── Internal service auth ─────────────────────────────────
# Used by Alertmanager to call the deploy freeze webhook
NERVE_INTERNAL_TOKEN=nerve-internal-dev-token

# ── OTel ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nerve-gateway
